<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Sentry Replay" 
           Manufacturer="Daniel Chalmers" 
           Version="!(bind.FileVersion.TeslaCam.exe)"
           UpgradeCode="A1B2C3D4-E5F6-4A5B-8C9D-0E1F2A3B4C5D">
    
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />
    
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="SentryReplay">
        <Component>
          <File Source="TeslaCam.exe">
            <Shortcut Directory="ProgramMenuFolder" Name="Sentry Replay" WorkingDirectory="INSTALLFOLDER" />
          </File>
        </Component>
        <Component>
          <Files Include="*.dll" />
          <Files Include="*.json" />
        </Component>
      </Directory>
    </StandardDirectory>
  </Package>
</Wix>
