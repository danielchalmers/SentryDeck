<Window x:Class="SentryDeck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fl="clr-namespace:FlyleafLib.Controls.WPF;assembly=FlyleafLib"
        xmlns:local="clr-namespace:SentryDeck"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Sentry Deck"
        MinWidth="1200"
        MinHeight="700"
        d:DataContext="{d:DesignInstance Type=local:MainWindowViewModel,
                                         IsDesignTimeCreatable=False}"
        Closing="Window_Closing"
        ContentRendered="Window_ContentRendered"
        Foreground="{DynamicResource TextControlForeground}"
        KeyDown="Window_KeyDown"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseDown="Window_PreviewMouseDown"
        mc:Ignorable="d">

    <Window.Resources>
        <!--
            Carries the window DataContext into resource-scoped bindings (the grouped clip view)
            and into the re-templated seek bar's overlays, which otherwise can't reach the
            view-model. Defined first so the StaticResource references below resolve.
        -->
        <local:BindingProxy x:Key="VmProxy"
                            Data="{Binding}" />

        <!--  Seek bar: accent played-track, growing thumb, keyboard focus ring, event marker + chunk seams  -->
        <Style x:Key="SeekSlider"
               TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Height" Value="24" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <!--  Not focusable: a keyboard-focused Slider consumes Left/Right/Home/End itself, moving
                  only the thumb (SeekPosition has no seek side effect outside a mouse gesture) and
                  desyncing it from the video. Unfocusable, the keys bubble to Window_KeyDown, whose
                  arrow shortcuts issue real 5-second seeks. Mouse seeking is unaffected.  -->
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border x:Name="SeekRail"
                                    Height="4"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                    CornerRadius="2" />
                            <Border Height="4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="2">
                                <Border.Width>
                                    <MultiBinding Converter="{local:SeekFillWidthConverter}">
                                        <Binding Path="Value"
                                                 RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>

                            <!--
                                Export selection: a translucent accent band over the marked in/out
                                range, plus a taller tick at each set mark (each shows on its own,
                                so a lone in-point is visible while placing the out-point). Same
                                offset math as the other overlays; hidden while no marks are set.
                            -->
                            <Border Height="8"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="2"
                                    IsHitTestVisible="False"
                                    Opacity="0.3"
                                    Visibility="{Binding Data.HasSelection, Converter={local:BoolToVisibilityConverter}, Source={StaticResource VmProxy}}">
                                <Border.Margin>
                                    <MultiBinding Converter="{local:SeekOffsetConverter}">
                                        <Binding Path="Data.SelectionStartPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Margin>
                                <Border.Width>
                                    <MultiBinding Converter="{local:SelectionWidthConverter}">
                                        <Binding Path="Data.SelectionStartPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding Path="Data.SelectionEndPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>

                            <Rectangle Width="2"
                                       Height="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                       IsHitTestVisible="False"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Visibility="{Binding Data.HasSelectionStart, Converter={local:BoolToVisibilityConverter}, Source={StaticResource VmProxy}}">
                                <Rectangle.Margin>
                                    <MultiBinding Converter="{local:SeekOffsetConverter}">
                                        <Binding Path="Data.SelectionStartPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Rectangle.Margin>
                            </Rectangle>

                            <Rectangle Width="2"
                                       Height="14"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                       IsHitTestVisible="False"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Visibility="{Binding Data.HasSelectionEnd, Converter={local:BoolToVisibilityConverter}, Source={StaticResource VmProxy}}">
                                <Rectangle.Margin>
                                    <MultiBinding Converter="{local:SeekOffsetConverter}">
                                        <Binding Path="Data.SelectionEndPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Rectangle.Margin>
                            </Rectangle>

                            <!--
                                Chunk seams: faint ~60s boundary ticks. Each tick offsets by
                                fraction × rail width; the ItemsControl matches the rail's width,
                                so ticks stay aligned on resize. Empty list draws nothing.
                            -->
                            <ItemsControl Focusable="False"
                                          IsHitTestVisible="False"
                                          ItemsSource="{Binding Data.ChunkBoundaries, Source={StaticResource VmProxy}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="1"
                                                   Height="8"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Fill="{DynamicResource ControlStrongFillColorDefaultBrush}"
                                                   Opacity="0.35">
                                            <Rectangle.Margin>
                                                <MultiBinding Converter="{local:SeekOffsetConverter}">
                                                    <Binding />
                                                    <Binding Path="ActualWidth"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Rectangle.Margin>
                                        </Rectangle>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--
                                Gap ticks: where the clip's media time skips over a wall-clock gap
                                (deleted/corrupt/excluded chunks, or a Sentry idle period). Same
                                offset math as the chunk seams above but visually distinct: a
                                dimmer, thinner mark so it doesn't compete with real chunk seams or
                                the event marker. Empty list (no gaps, or media not opened yet)
                                draws nothing.
                            -->
                            <ItemsControl Focusable="False"
                                          IsHitTestVisible="False"
                                          ItemsSource="{Binding Data.GapPositions, Source={StaticResource VmProxy}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Grid />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="1"
                                                   Height="6"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Fill="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Opacity="0.6">
                                            <Rectangle.Margin>
                                                <MultiBinding Converter="{local:SeekOffsetConverter}">
                                                    <Binding />
                                                    <Binding Path="ActualWidth"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Rectangle.Margin>
                                        </Rectangle>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Event marker: a reason-colored tick at the moment the incident happened (hover for details; jump via the button or E).  -->
                            <Border Width="3"
                                    Height="16"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    CornerRadius="1.5"
                                    IsHitTestVisible="False"
                                    ToolTip="{Binding Data.EventMarkerTooltip, Source={StaticResource VmProxy}}"
                                    Visibility="{Binding Data.HasEventMarker, Converter={local:BoolToVisibilityConverter}, Source={StaticResource VmProxy}}">
                                <Border.Style>
                                    <!--  Reason color via DynamicResource (keyed by ReasonKey) so the marker re-colors on a live OS theme switch.  -->
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Data.SelectedClip.Event, Converter={local:ReasonKeyConverter}, Source={StaticResource VmProxy}}"
                                                         Value="sentry">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Data.SelectedClip.Event, Converter={local:ReasonKeyConverter}, Source={StaticResource VmProxy}}"
                                                         Value="honk">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Data.SelectedClip.Event, Converter={local:ReasonKeyConverter}, Source={StaticResource VmProxy}}"
                                                         Value="alert">
                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Data.SelectedClip.Event, Converter={local:ReasonKeyConverter}, Source={StaticResource VmProxy}}"
                                                         Value="saved">
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Margin>
                                    <MultiBinding Converter="{local:SeekOffsetConverter}">
                                        <Binding Path="Data.EventMarkerPosition"
                                                 Source="{StaticResource VmProxy}" />
                                        <Binding ElementName="SeekRail"
                                                 Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Margin>
                            </Border>

                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="Transparent"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="Transparent"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <!--
                                        The scale transform lives on the Thumb (not the inner Grid) so
                                        it sits in the Slider template's name scope — the hover storyboard
                                        below targets ThumbScale by name, which fails across the nested
                                        Thumb-template scope.
                                    -->
                                    <Thumb x:Name="Thumb"
                                           RenderTransformOrigin="0.5,0.5">
                                        <Thumb.RenderTransform>
                                            <ScaleTransform x:Name="ThumbScale" />
                                        </Thumb.RenderTransform>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="20"
                                                      Height="20"
                                                      Background="Transparent">
                                                    <Ellipse x:Name="FocusRing"
                                                             Width="20"
                                                             Height="20"
                                                             Fill="Transparent"
                                                             Stroke="{DynamicResource AccentFillColorDefaultBrush}"
                                                             StrokeThickness="2"
                                                             Visibility="{Binding IsKeyboardFocused, RelativeSource={RelativeSource AncestorType=Slider}, Converter={local:BoolToVisibilityConverter}}" />
                                                    <Ellipse Width="14"
                                                             Height="14"
                                                             Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                             Stroke="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                                                             StrokeThickness="2" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.25"
                                                             Duration="{StaticResource MotionFaster}" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.25"
                                                             Duration="{StaticResource MotionFaster}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="{StaticResource MotionFast}" />
                                            <DoubleAnimation Storyboard.TargetName="ThumbScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="{StaticResource MotionFast}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CameraViewTileButton"
               TargetType="RadioButton">
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TileBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource ControlCornerRadius}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <!--
                                No scale animation here: these tiles host the live mini-camera previews, and the
                                Flyleaf surface follows the tile's render transform, so scaling would shift the video.
                            -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <!--  A single selected signal: the 2px accent border.  -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="TileBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Hyperlink"
               BasedOn="{StaticResource {x:Type Hyperlink}}">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
            <Setter Property="TextDecorations" Value="None" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <!--  Underline on hover so clickability isn't conveyed by color alone.  -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Promo titles sit BELOW the section headers in the hierarchy (BodyStrong, not larger).  -->
        <Style x:Key="ProjectTitleTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="ProjectDescriptionTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource TextControlPlaceholderForeground}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!--  About page: section heading inside a card.  -->
        <Style x:Key="AboutSectionHeader"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Margin" Value="0,22,0,10" />
        </Style>

        <!--  About page: keyboard keycap chip + its label.  -->
        <Style x:Key="Keycap"
               TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="KeycapText"
               TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AboutShortcutLabel"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="ClipListTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                             Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!--  Metadata is demoted with contrast (semantic brushes), not opacity.  -->
        <Style x:Key="ClipListSecondaryTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource ClipListTextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="ClipListTertiaryTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource ClipListTextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>

        <!--  Day-grouped clip view; grouping lives in XAML via the shared VmProxy above.  -->
        <CollectionViewSource x:Key="GroupedClips"
                              Source="{Binding Data.FilteredClips, Source={StaticResource VmProxy}}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription Converter="{local:DateOnlyConverter}"
                                          PropertyName="Timestamp" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!--  Shared clip context menu (Tag on the item = the view-model).  -->
        <ContextMenu x:Key="ClipContextMenu">
            <MenuItem Header="Open clip folder"
                      Command="{Binding PlacementTarget.Tag.OpenClipFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8B7;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Show on map"
                      Command="{Binding PlacementTarget.Tag.ShowOnMapCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xECAF;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
            <!--  ±30s of front-camera footage around the event moment, stream-copied (no re-encode).  -->
            <MenuItem Header="Save event clip…"
                      Command="{Binding PlacementTarget.Tag.SaveEventClipCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE792;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
            <Separator />
            <MenuItem Header="Copy clip name"
                      Command="{Binding PlacementTarget.Tag.CopyClipNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy timestamp"
                      Command="{Binding PlacementTarget.Tag.CopyTimestampCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Copy folder path"
                      Command="{Binding PlacementTarget.Tag.CopyClipPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <TextBlock Text="&#xE8C8;" Style="{StaticResource AppGlyph}" />
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>

    <Window.Triggers>
        <!--  Fade the window in on launch  -->
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid Visibility="{Binding ShowMainContent, Converter={local:BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"
                                  MinWidth="260"
                                  MaxWidth="440" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Sidebar (semi-transparent Layer so Mica shows through)  -->
            <Grid Grid.Column="0"
                  Background="{DynamicResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--
                    Search box. The Fluent TextBox supplies its own focus underline and inline
                    clear button, so this chrome stays neutral (no accent outline on focus) and
                    adds no second clear button — only the surrounding pill + a leading icon.
                -->
                <Border Grid.Row="0"
                        Margin="12,12,12,8"
                        Padding="8,0,2,0"
                        Background="{DynamicResource TextControlBackground}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource ControlCornerRadius}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="&#xE721;"
                                   Margin="2,0,8,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource AppGlyph}" />

                        <Grid Grid.Column="1">
                            <TextBox x:Name="SearchBox"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8,8,8"
                                     VerticalContentAlignment="Center"
                                     FontSize="14"
                                     AutomationProperties.Name="Search clips"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextControlForeground}" />
                            <TextBlock Text="Search clips, places, events…"
                                       Padding="10,8,8,8"
                                       VerticalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextControlPlaceholderForeground}"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Hidden" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterText}"
                                                         Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </Border>

                <!--  Clip list (day-grouped incident log)  -->
                <ListBox x:Name="ClipListBox"
                         Grid.Row="1"
                         Margin="4,0"
                         Padding="0,0,6,0"
                         Background="Transparent"
                         BorderThickness="0"
                         IsSynchronizedWithCurrentItem="False"
                         ItemsSource="{Binding Source={StaticResource GroupedClips}}"
                         PreviewMouseLeftButtonUp="ClipListBox_PreviewMouseLeftButtonUp"
                         PreviewMouseRightButtonDown="ClipListBox_PreviewMouseRightButtonDown"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectedItem="{Binding SelectedClip, Mode=TwoWay}"
                         VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name, Converter={local:DayGroupHeaderConverter}}"
                                               Margin="12,12,8,4"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource AppCaption}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="4,2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="ContextMenu" Value="{StaticResource ClipContextMenu}" />
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="88">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Reason stripe (hidden when the row is accent-selected)  -->
                                <Rectangle Grid.Column="0"
                                           Width="3"
                                           Margin="0,10"
                                           HorizontalAlignment="Left"
                                           RadiusX="1.5"
                                           RadiusY="1.5">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <!--  Reason color via DynamicResource (keyed by ReasonKey) so the stripe re-colors on a live OS theme switch.  -->
                                            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Event, Converter={local:ReasonKeyConverter}}"
                                                             Value="sentry">
                                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Event, Converter={local:ReasonKeyConverter}}"
                                                             Value="honk">
                                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorCautionBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Event, Converter={local:ReasonKeyConverter}}"
                                                             Value="alert">
                                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Event, Converter={local:ReasonKeyConverter}}"
                                                             Value="saved">
                                                    <Setter Property="Fill" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                </DataTrigger>
                                                <!--  Hidden (not Collapsed) so the 3px column keeps its width and the thumbnail doesn't shift on select.  -->
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                             Value="True">
                                                    <Setter Property="Visibility" Value="Hidden" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <!--  Thumbnail (with glyph fallback + now-playing marker)  -->
                                <Border Grid.Column="1"
                                        Width="96"
                                        Height="72"
                                        Margin="8,0,0,0"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        ClipToBounds="True"
                                        CornerRadius="4">
                                    <Grid>
                                        <TextBlock Text="&#xE714;"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="22"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Style="{StaticResource AppGlyph}"
                                                   Visibility="{Binding ThumbnailPath, Converter={local:ThumbnailConverter}, ConverterParameter=fallback}" />
                                        <Image Source="{Binding ThumbnailPath, Converter={local:ThumbnailConverter}}"
                                               Stretch="UniformToFill" />
                                        <Border Margin="0,0,4,4"
                                                Padding="4,1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="#C0000000"
                                                CornerRadius="3">
                                            <Border.Visibility>
                                                <MultiBinding Converter="{local:NowPlayingConverter}">
                                                    <Binding />
                                                    <Binding Path="Data.NowPlayingClip"
                                                             Source="{StaticResource VmProxy}" />
                                                </MultiBinding>
                                            </Border.Visibility>
                                            <TextBlock Text="&#xE768;"
                                                       FontSize="10"
                                                       Foreground="White"
                                                       Style="{StaticResource AppGlyph}" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!--  Info: date/time and reason/duration are justified to opposite ends of each row so the layout reads intentionally without middot separators.  -->
                                <Grid Grid.Column="2"
                                      Margin="12,0,8,0"
                                      VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, Converter={local:FriendlyDateConverter}, ConverterParameter=date}"
                                                   FontWeight="SemiBold"
                                                   Style="{StaticResource ClipListTextBlock}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Name}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Timestamp, Converter={local:FriendlyDateConverter}, ConverterParameter=time}"
                                                   Margin="8,0,0,0"
                                                   Style="{StaticResource ClipListSecondaryTextBlock}" />
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Event, Converter={local:ReasonLabelConverter}}"
                                                   Style="{StaticResource ClipListSecondaryTextBlock}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Converter={local:ClipDurationConverter}}"
                                                   Margin="8,0,0,0"
                                                   Style="{StaticResource ClipListTertiaryTextBlock}" />
                                    </Grid>

                                    <!--  Location: fixed-width pin column (clips the glyph's wide advance) + city with a small controlled gap.  -->
                                    <Grid Grid.Row="2"
                                          Margin="0,3,0,0"
                                          Visibility="{Binding Event, Converter={local:MapAvailabilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xECAF;"
                                                   Width="13"
                                                   VerticalAlignment="Center"
                                                   FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Event.City}"
                                                   Margin="5,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource ClipListSecondaryTextBlock}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--  Filtered-empty state (only while a search yields nothing)  -->
                <StackPanel Grid.Row="1"
                            Margin="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ClipCount}" Value="0" />
                                        <Condition Binding="{Binding IsLoadingClips}" Value="False" />
                                        <Condition Binding="{Binding HasFilterText}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE721;"
                               HorizontalAlignment="Center"
                               FontSize="28"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Style="{StaticResource AppGlyph}" />
                    <TextBlock Text="No clips match your search."
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource AppBody}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!--  Subtle animated loading bar shown while the clip list is (re)scanned  -->
                <ProgressBar Grid.Row="1"
                             Height="3"
                             Margin="4,0"
                             VerticalAlignment="Top"
                             Background="Transparent"
                             BorderThickness="0"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoadingClips, Converter={local:BoolToVisibilityConverter}}" />

                <!--  Utility action bar (single row, divided from the list)  -->
                <Border Grid.Row="2"
                        Padding="12,10"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding OpenFolderCommand}"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.Name="Select folder"
                                Style="{StaticResource PressScaleButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;"
                                           Style="{StaticResource AppGlyphInButton}" />
                                <TextBlock Text="Select folder"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource AppBodyStrong}" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding RefreshClipsCommand}"
                                AutomationProperties.Name="Rescan folder"
                                Style="{StaticResource SubtleIconButton}"
                                ToolTip="Rescan the current folder for clips">
                            <TextBlock Text="&#xE72C;"
                                       Style="{StaticResource AppGlyph}" />
                        </Button>

                        <Grid Grid.Column="4">
                            <Button Command="{Binding ToggleAboutCommand}"
                                    AutomationProperties.Name="About and help"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="About / Help">
                                <TextBlock Text="&#xE946;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>
                            <Border Width="8"
                                    Height="8"
                                    Margin="0,4,4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource SystemFillColorAttentionBrush}"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    ToolTip="Update available"
                                    Visibility="{Binding HasUpdateBadge, Converter={local:BoolToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!--  Splitter  -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="Transparent" />

            <!--  Video Player Area (opaque: frames the native video surface)  -->
            <Grid Grid.Column="2"
                  Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Video Container  -->
                <Grid Grid.Row="0"
                      Margin="16,16,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="FlyleafHostPool"
                          Visibility="Collapsed">
                        <!--  KeyBindings=None: shortcuts are app-wide (Window_KeyDown acts on all cameras);
                              Flyleaf's per-surface key handling would pause/seek a single camera only.  -->
                        <fl:FlyleafHost x:Name="FrontFlyleafHost" KeyBindings="None" />
                        <fl:FlyleafHost x:Name="BackFlyleafHost" KeyBindings="None" />
                        <fl:FlyleafHost x:Name="LeftFlyleafHost" KeyBindings="None" />
                        <fl:FlyleafHost x:Name="RightFlyleafHost" KeyBindings="None" />
                        <fl:FlyleafHost x:Name="LeftPillarFlyleafHost" KeyBindings="None" />
                        <fl:FlyleafHost x:Name="RightPillarFlyleafHost" KeyBindings="None" />
                    </Grid>

                    <!--  Video Player  -->
                    <Grid Grid.RowSpan="2"
                          Visibility="{Binding ShowVideoHosts, Converter={local:BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Focusable: keyboard focus is parked here after a camera-tile click so app-wide
                              shortcuts bubble to Window_KeyDown. Focusing the Window instead doesn't work —
                              it's a focus scope, so WPF redirects to the last focused child (often a clip
                              ListBoxItem, which swallows Space/arrows for list navigation).  -->
                        <Border x:Name="VideoContainer"
                                Grid.Row="0"
                                Background="Black"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="6"
                                Focusable="True">
                            <Grid>
                                <Grid Visibility="{Binding IsGridViewSelected, Converter={local:BoolToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0"
                                            Grid.Column="0"
                                            Margin="0,0,1,1"
                                            Background="Black"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="GridFrontHostSlot" />
                                            <Border Margin="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#A0000000"
                                                    CornerRadius="4">
                                                <TextBlock Text="Front"
                                                           FontSize="12"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="0"
                                            Grid.Column="1"
                                            Margin="1,0,0,1"
                                            Background="Black"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="GridRearHostSlot" />
                                            <Border Margin="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#A0000000"
                                                    CornerRadius="4">
                                                <TextBlock Text="Rear"
                                                           FontSize="12"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,1,1,0"
                                            Background="Black"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="GridLeftHostSlot" />
                                            <Border Margin="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#A0000000"
                                                    CornerRadius="4">
                                                <TextBlock Text="Left"
                                                           FontSize="12"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="1,1,0,0"
                                            Background="Black"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ContentControl x:Name="GridRightHostSlot" />
                                            <Border Margin="10"
                                                    Padding="8,3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Background="#A0000000"
                                                    CornerRadius="4">
                                                <TextBlock Text="Right"
                                                           FontSize="12"
                                                           Foreground="White" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid Visibility="{Binding IsSingleCameraViewSelected, Converter={local:BoolToVisibilityConverter}}">
                                    <ContentControl x:Name="PrimaryCameraHostSlot" />
                                    <Border Margin="14"
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Background="#A0000000"
                                            CornerRadius="4">
                                        <TextBlock Text="{Binding ActiveCameraLabel}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="White" />
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,10,0,0"
                                Padding="5"
                                Background="{DynamicResource LayerFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <!--  One tile per view the current clip offers: the grid plus each recorded camera (four on HW3, six on HW4/AI4).
                                  Camera tiles carry a preview slot that registers itself with the code-behind (CameraTileSlot_Loaded), which re-parents each camera's Flyleaf host into it.  -->
                            <ItemsControl ItemsSource="{Binding CameraViewOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:CameraViewOption}">
                                        <RadioButton Command="{Binding DataContext.SelectCameraViewCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                     CommandParameter="{Binding ViewId}"
                                                     AutomationProperties.Name="{Binding AutomationName}"
                                                     GroupName="CameraViewMode"
                                                     IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                     Style="{StaticResource CameraViewTileButton}"
                                                     ToolTip="{Binding ToolTip}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="64" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4"
                                                        Visibility="{Binding IsGrid, Converter={local:BoolToVisibilityConverter}}">
                                                    <TextBlock Text="&#xE80A;"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="34"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Style="{StaticResource AppGlyph}" />
                                                </Border>
                                                <Border Grid.Row="0"
                                                        Background="Black"
                                                        ClipToBounds="True"
                                                        CornerRadius="4"
                                                        Visibility="{Binding IsCamera, Converter={local:BoolToVisibilityConverter}}">
                                                    <Grid>
                                                        <ContentControl Loaded="CameraTileSlot_Loaded" />
                                                        <!--  Single-screen icon: this camera is the main view (cf. the 2x2 grid icon)  -->
                                                        <Border Margin="18"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                CornerRadius="3"
                                                                Visibility="{Binding IsSelected, Converter={local:BoolToVisibilityConverter}}" />
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Label}"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Center"
                                                           FontSize="12"
                                                           FontWeight="SemiBold" />
                                            </Grid>
                                        </RadioButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <!--  Status Overlay (Loading/Rendering/Error)  -->
                    <Border Grid.RowSpan="2"
                            Background="#80000000"
                            Visibility="{Binding ShowStatusOverlay, Converter={local:BoolToVisibilityConverter}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowStatusOverlay}"
                                                 Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0"
                                                                     To="1"
                                                                     Duration="0:0:0.2">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseOut" />
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel MaxWidth="500"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <!--  Idle: clips are loaded but none is picked yet  -->
                            <StackPanel Visibility="{Binding HasNoClipSelected, Converter={local:BoolToVisibilityConverter}}">
                                <TextBlock Text="&#xE714;"
                                           FontSize="40"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Style="{StaticResource AppGlyph}" />
                                <TextBlock Text="Select a clip to begin"
                                           Margin="0,12,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource AppSubtitle}" />
                                <TextBlock Text="Your dashcam timeline is on the left."
                                           Margin="0,4,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Style="{StaticResource AppBody}" />
                            </StackPanel>

                            <!--  Loading / rendering status  -->
                            <StackPanel Visibility="{Binding IsLoading, Converter={local:BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding LoadingStatusText}"
                                           Margin="0,0,0,16"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Style="{StaticResource AppSubtitle}" />
                                <ProgressBar Width="300"
                                             Height="6"
                                             IsIndeterminate="{Binding IsIndeterminateProgress}"
                                             Maximum="100"
                                             Value="{Binding RenderProgressPercent, Mode=OneWay}" />
                            </StackPanel>

                            <!--  Error / first-run empty state  -->
                            <StackPanel Visibility="{Binding ShowErrorOverlay, Converter={local:BoolToVisibilityConverter}}">
                                <Border Width="64"
                                        Height="64"
                                        Margin="0,0,0,16"
                                        HorizontalAlignment="Center"
                                        CornerRadius="32">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmptyState}"
                                                             Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="26">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource AppGlyph}">
                                                <Setter Property="Text" Value="&#xE783;" />
                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEmptyState}"
                                                                 Value="True">
                                                        <Setter Property="Text" Value="&#xE8B7;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{Binding ErrorTitle}"
                                           Margin="0,0,0,8"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource AppSubtitle}">
                                            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmptyState}"
                                                             Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding ErrorDetails}"
                                           MaxWidth="380"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource AppBody}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button Content="Select folder"
                                        Command="{Binding OpenFolderCommand}"
                                        Margin="0,20,0,0"
                                        Padding="24,8"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Visibility="{Binding IsEmptyState, Converter={local:BoolToVisibilityConverter}}" />
                                <Button Content="Download FFmpeg"
                                        Command="{Binding DownloadFFmpegCommand}"
                                        Margin="0,20,0,0"
                                        Padding="24,8"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Visibility="{Binding ShowFFmpegDownloadButton, Converter={local:BoolToVisibilityConverter}}" />
                                <Button Content="Dismiss"
                                        Command="{Binding DismissErrorCommand}"
                                        Margin="0,12,0,0"
                                        Padding="24,8"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource DefaultButtonStyle}"
                                        Visibility="{Binding CanDismissError, Converter={local:BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1">
                    <!--
                        Trim panel: appears above the player controls while cutting a range.
                        Deliberately wordy — labeled steps plus a hint line that walks through
                        start → end → export, so the feature needs no manual. All state lives in
                        the view-model (IsTrimming + the selection marks); closing always discards
                        the marks.
                    -->
                    <Border Padding="16,10"
                            Background="{DynamicResource LayerFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,1"
                            Visibility="{Binding IsTrimming, Converter={local:BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,14,0"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal">
                                <TextBlock Text="&#xE8C6;"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource AppGlyph}" />
                                <TextBlock Text="Trim clip"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding MarkSelectionStartCommand}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Set start"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    ToolTip="Mark the start of the cut at the playhead (I)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="["
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Set start"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Command="{Binding MarkSelectionEndCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Set end"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    ToolTip="Mark the end of the cut at the playhead (O)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="]"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="Set end"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!--  Live guidance: which step is next, then the selected length.  -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding TrimHintText}"
                                       Margin="16,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis" />

                            <Button Grid.Column="4"
                                    Command="{Binding ExportSelectionCommand}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Export trimmed clip"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTip="Save the marked section as an MP4 — lossless and instant (Ctrl+E)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE792;"
                                               Style="{StaticResource AppGlyphInButton}" />
                                    <TextBlock Text="Export…"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="5"
                                    Content="Cancel"
                                    Command="{Binding CancelTrimCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Cancel trim"
                                    Style="{StaticResource DefaultButtonStyle}"
                                    ToolTip="Close and discard the marks (Esc)" />
                        </Grid>
                    </Border>

                    <!--  Player Controls: transport · event/trim · scrubber · time · speed, one row  -->
                    <Border Padding="16,10"
                            Background="{DynamicResource LayerFillColorDefaultBrush}">
                        <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Transport cluster  -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Command="{Binding PreviousCommand}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Previous clip"
                                    IsEnabled="{Binding CanGoPrevious}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Previous clip (Ctrl+Left)">
                                <TextBlock Text="&#xE892;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>

                            <Button Command="{Binding StepFrameBackwardCommand}"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Previous frame"
                                    IsEnabled="{Binding CanSeek}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Previous frame (,)">
                                <TextBlock Text="&#xE76B;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>

                            <Button x:Name="PlayPauseButton"
                                    Content="{Binding PlayPauseIcon}"
                                    Command="{Binding PlayPauseCommand}"
                                    Width="56"
                                    Height="40"
                                    Margin="10,0"
                                    VerticalAlignment="Center"
                                    FontFamily="{DynamicResource SymbolThemeFontFamily}"
                                    FontSize="20"
                                    AutomationProperties.Name="Play or pause"
                                    IsEnabled="{Binding CanPlayPause}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTip="Play/Pause (Space)" />

                            <Button Command="{Binding StepFrameForwardCommand}"
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Next frame"
                                    IsEnabled="{Binding CanSeek}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Next frame (.)">
                                <TextBlock Text="&#xE76C;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>

                            <Button Command="{Binding NextCommand}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Next clip"
                                    IsEnabled="{Binding CanGoNext}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Next clip (Ctrl+Right)">
                                <TextBlock Text="&#xE893;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>

                            <Button Command="{Binding StopCommand}"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Stop"
                                    IsEnabled="{Binding CanStop}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Stop">
                                <TextBlock Text="&#xE71A;"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>
                        </StackPanel>

                        <!--
                            Event + Trim cluster. Unlike the transport icons (universal player
                            symbols), these two are app-specific actions, so they carry text
                            labels; a divider separates them from the transport cluster.
                        -->
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Rectangle Width="1"
                                       Height="24"
                                       Margin="14,0,4,0"
                                       VerticalAlignment="Center"
                                       Fill="{DynamicResource DividerStrokeColorDefaultBrush}" />

                            <!--  Jump straight to the moment the incident happened  -->
                            <Button Command="{Binding JumpToEventCommand}"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Jump to event"
                                    IsEnabled="{Binding HasEventMarker}"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Jump to the moment the event fired (E)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7C1;"
                                               Style="{StaticResource AppGlyphInButton}" />
                                    <TextBlock Text="Event"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!--  Opens the trim panel (above this bar) for cutting a shareable MP4.  -->
                            <Button Command="{Binding ToggleTrimmingCommand}"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="Trim clip"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Cut a section of this clip to share (I / O to mark)">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C6;"
                                               Style="{StaticResource AppGlyphInButton}" />
                                    <TextBlock Text="Trim"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!--  Scrubber (carries the event marker + chunk seams)  -->
                        <Slider x:Name="SeekSlider"
                                Grid.Column="2"
                                Margin="16,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Seek"
                                IsEnabled="{Binding CanSeek}"
                                Maximum="1"
                                Minimum="0"
                                PreviewMouseDown="SeekSlider_PreviewMouseDown"
                                PreviewMouseUp="SeekSlider_PreviewMouseUp"
                                Style="{StaticResource SeekSlider}"
                                ValueChanged="SeekSlider_ValueChanged"
                                Value="{Binding SeekPosition, Mode=TwoWay}" />

                        <!--  Time readout  -->
                        <TextBlock Grid.Column="3"
                                   VerticalAlignment="Center"
                                   FontFamily="Consolas"
                                   FontSize="13">
                            <Run Text="{Binding PositionText, Mode=OneWay}"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Run Text=" / "
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            <Run Text="{Binding DurationText, Mode=OneWay}"
                                 Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </TextBlock>

                        <!--  Playback speed stepper: walks a fixed ladder (0.25x to 16x, Flyleaf's ceiling)
                              instead of listing every speed in a dropdown. Click the readout to reset to 1x.  -->
                        <!--  Zoom readout + reset — shown only while a camera is magnified. Lives in the chrome
                              because the native video surface sits above WPF, so nothing can draw over the video.  -->
                        <Button Grid.Column="4"
                                Command="{Binding ResetZoomCommand}"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Reset zoom"
                                Style="{StaticResource SubtleIconButton}"
                                ToolTip="Reset zoom — or double-click the video (scroll to zoom, drag to pan)"
                                Visibility="{Binding IsActiveViewZoomed, Converter={local:BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71E;"
                                           Style="{StaticResource AppGlyphInButton}" />
                                <TextBlock Text="{Binding ActiveZoomText}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="5"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Command="{Binding DecreaseSpeedCommand}"
                                    AutomationProperties.Name="Slower"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Slower (Shift+,)">
                                <TextBlock Text="&#xE738;"
                                           FontSize="13"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>
                            <Button MinWidth="72"
                                    Command="{Binding ResetSpeedCommand}"
                                    AutomationProperties.Name="Playback speed"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Playback speed — click to reset to 1x">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEC57;"
                                               FontSize="15"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Style="{StaticResource AppGlyphInButton}" />
                                    <TextBlock Text="{Binding PlaybackSpeedText}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding IncreaseSpeedCommand}"
                                    AutomationProperties.Name="Faster"
                                    Style="{StaticResource SubtleIconButton}"
                                    ToolTip="Faster (Shift+.)">
                                <TextBlock Text="&#xE710;"
                                           FontSize="13"
                                           Style="{StaticResource AppGlyph}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
              Visibility="{Binding ShowAboutPage, Converter={local:BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="16,12"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Command="{Binding ToggleAboutCommand}"
                            AutomationProperties.Name="Back to player"
                            Style="{StaticResource SubtleIconButton}"
                            ToolTip="Back to player">
                        <TextBlock Text="&#xE72B;"
                                   Style="{StaticResource AppGlyph}" />
                    </Button>
                    <TextBlock Text="About / Help"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Style="{StaticResource AppTitle}" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="24"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <!--  App identity  -->
                            <StackPanel Orientation="Horizontal">
                                <Image Width="52"
                                       Height="52"
                                       Source="{StaticResource AppIconImage}" />
                                <StackPanel Margin="16,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Sentry Deck"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="Version" />
                                        <Run Text="{Binding FileVersion, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Review TeslaCam footage in a single timeline with easy clip navigation."
                                       Margin="0,16,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <!--  Quick start  -->
                            <TextBlock Text="Quick start"
                                       Style="{StaticResource AboutSectionHeader}" />
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="24"
                                        Height="24"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="12">
                                    <TextBlock Text="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Select folder"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Run Text="to pick your TeslaCam directory — USB drives are found automatically." />
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="24"
                                        Height="24"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="12">
                                    <TextBlock Text="2"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Choose a clip" />
                                    <Run Text="from the timeline on the left to start playback." />
                                </TextBlock>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="24"
                                        Height="24"
                                        VerticalAlignment="Top"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="12">
                                    <TextBlock Text="3"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="Scrub and switch cameras" />
                                    <Run Text="with the controls below the video, or click any camera to enlarge it." />
                                </TextBlock>
                            </Grid>

                            <!--  Keyboard shortcuts  -->
                            <TextBlock Text="Keyboard shortcuts"
                                       Style="{StaticResource AboutSectionHeader}" />
                            <StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Space" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Play / pause" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="&#x2190; / &#x2192;" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Seek 5 seconds" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="&#x2190; / &#x2192;" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Previous / next clip" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="F" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Focus search (also F3 or F6)" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="," Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="." Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Step one frame back / forward" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Shift" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text=", / ." Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Slower / faster playback" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="E" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Jump to the event moment" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="1 – 7" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Switch camera view (one key per tile)" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="I" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="O" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Mark the trim start / end" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,8"
                                            Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="E" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Export the trimmed section as MP4" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource Keycap}">
                                        <TextBlock Text="Esc" Style="{StaticResource KeycapText}" />
                                    </Border>
                                    <TextBlock Text="Cancel the trim" Style="{StaticResource AboutShortcutLabel}" />
                                </StackPanel>
                            </StackPanel>

                            <!--  Playback notes  -->
                            <TextBlock Text="Playback notes"
                                       Style="{StaticResource AboutSectionHeader}" />
                            <TextBlock Text="Zoom any camera — including the grid — to read a plate: scroll or pinch to zoom toward the pointer, drag to pan, and double-click (or the zoom button) to reset. Each angle zooms independently."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="FFmpeg 8.1 shared binaries are required for playback. Use the Download FFmpeg button when prompted."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="If clips do not appear, confirm the folder contains a TeslaCam directory."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <Border Padding="20"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="App info"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Grid Margin="0,8,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="12"
                                            Height="12"
                                            Margin="0,4,0,0"
                                            VerticalAlignment="Top"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="6"
                                            Visibility="{Binding HasUpdateBadge, Converter={local:BoolToVisibilityConverter}}" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding UpdateStatusTitle}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextControlForeground}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextControlForeground}"
                                                   TextWrapping="Wrap">
                                            <Run Text="{Binding UpdateStatusDetails, Mode=OneWay}" />
                                            <Run Text=" " />
                                            <Hyperlink NavigateUri="{Binding LatestReleaseUrl}"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                Learn more
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Version:"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextControlPlaceholderForeground}"
                                               TextAlignment="Right" />
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="2"
                                               Text="{Binding FileVersion}"
                                               Foreground="{DynamicResource TextControlForeground}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Runtime:"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextControlPlaceholderForeground}"
                                               TextAlignment="Right" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Text="{Binding RuntimeDescription}"
                                               Foreground="{DynamicResource TextControlForeground}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="OS:"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextControlPlaceholderForeground}"
                                               TextAlignment="Right" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="2"
                                               Text="{Binding OsDescription}"
                                               Foreground="{DynamicResource TextControlForeground}" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
