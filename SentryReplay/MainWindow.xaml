<Window x:Class="SentryReplay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        xmlns:local="clr-namespace:SentryReplay"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Sentry Replay"
        MinWidth="1200" MinHeight="700"
        d:DataContext="{d:DesignInstance Type=local:MainWindow}"
        Background="#1a1a1a" Closing="Window_Closing"
        ContentRendered="Window_ContentRendered" KeyDown="Window_KeyDown"
        mc:Ignorable="d">

    <Window.Resources>
        <!--  Button Style  -->
        <Style x:Key="PlayerButton" TargetType="Button">
            <Setter Property="Background" Value="#333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#666" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#222" />
                                <Setter Property="Foreground" Value="#666" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Slider Style for Seek Bar  -->
        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="8,0" />
        </Style>

        <Style TargetType="Hyperlink"
               BasedOn="{StaticResource {x:Type Hyperlink}}">
            <Setter Property="TextDecorations" Value="None" />
        </Style>

        <Style x:Key="ProjectTitleTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="ProjectDescriptionTextBlock"
               TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="#aaa" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Visibility="{Binding ShowMainContent, Converter={local:BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  Sidebar  -->
            <Grid Grid.Column="0"
                  Background="#252525">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Search box  -->
                <Border Grid.Row="0"
                        Margin="8,8,8,4"
                        Background="#333">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Padding="12,10" VerticalContentAlignment="Center"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="14" Foreground="White"
                                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Padding="12,10" VerticalAlignment="Center"
                                   FontSize="14" Foreground="#666"
                                   IsHitTestVisible="False" Text="Search clips...">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Hidden" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilterText}"
                                                     Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!--  Clip list  -->
                <ListBox x:Name="ClipListBox"
                         Grid.Row="1"
                         Margin="4,0"
                         Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding FilteredClips}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectedItem="{Binding SelectedClip, Mode=TwoWay}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8" />
                            <Setter Property="Margin" Value="4" />
                            <Setter Property="Background" Value="#333" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Padding="{TemplateBinding Padding}"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#444" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1e88e5" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="72">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Thumbnail  -->
                                <Border Grid.Column="0"
                                        Background="#222" CornerRadius="4">
                                    <Image HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Source="{Binding ThumbnailPath}"
                                           Stretch="UniformToFill" />
                                </Border>

                                <!--  Info  -->
                                <StackPanel Grid.Column="1"
                                            Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="White"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12" Foreground="#aaa"
                                               Text="{Binding Timestamp, StringFormat='{}{0:g}'}" />
                                    <TextBlock Margin="0,2,0,0"
                                               FontSize="11" Foreground="#888">
                                        <Run Text="{Binding Chunks.Count, Mode=OneWay}" />
                                        <Run Text="chunks" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!--  Folder picker  -->
                <StackPanel Grid.Row="2"
                            Margin="8">
                    <Button Padding="12"
                            Command="{Binding OpenFolderCommand}"
                            Content="📁 Select Folder"
                            Style="{StaticResource PlayerButton}" />
                    <Button Margin="0,8,0,0"
                            Padding="12"
                            Command="{Binding ToggleAboutCommand}"
                            Content="ℹ️ About / Help"
                            Style="{StaticResource PlayerButton}" />
                </StackPanel>
            </Grid>

            <!--  Splitter  -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          Background="#333" />

            <!--  Video Player Area  -->
            <Grid Grid.Column="2"
                  Background="#1a1a1a">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Video Container  -->
                <Grid Grid.Row="0">
                    <!--  Video Player  -->
                    <Viewbox Stretch="Uniform">
                        <!--  HW3 = 1280x960, HW4 = 2896x1876  -->
                        <ffme:MediaElement x:Name="MediaElement"
                                           Height="960"
                                           LoadedBehavior="Manual" UnloadedBehavior="Manual" />
                    </Viewbox>

                    <!--  Status Overlay (Loading/Rendering/Error)  -->
                    <Border Background="#80000000"
                            Visibility="{Binding ShowStatusOverlay, Converter={local:BoolToVisibilityConverter}}">
                        <StackPanel MaxWidth="500"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!--  Loading/Rendering status  -->
                            <StackPanel Visibility="{Binding IsLoading, Converter={local:BoolToVisibilityConverter}}">
                                <TextBlock Margin="0,0,0,16" HorizontalAlignment="Center"
                                           FontSize="18" Foreground="White"
                                           Text="{Binding LoadingStatusText}" />
                                <ProgressBar Width="300" Height="8"
                                             IsIndeterminate="{Binding IsIndeterminateProgress}"
                                             Maximum="100"
                                             Value="{Binding RenderProgressPercent, Mode=OneWay}" />
                            </StackPanel>

                            <!--  Error display  -->
                            <StackPanel Visibility="{Binding ShowErrorOverlay, Converter={local:BoolToVisibilityConverter}}">
                                <TextBlock Margin="0,0,0,16" HorizontalAlignment="Center"
                                           FontSize="48" Text="⚠️" />
                                <TextBlock Margin="0,0,0,8" HorizontalAlignment="Center"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="#ff6b6b"
                                           Text="{Binding ErrorTitle}" />
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="14" Foreground="#aaa"
                                           Text="{Binding ErrorDetails}"
                                           TextAlignment="Center" TextWrapping="Wrap" />
                                <Button Margin="0,20,0,0" Padding="24,10"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DownloadFFmpegCommand}"
                                        Content="Download FFmpeg"
                                        Style="{StaticResource PlayerButton}"
                                        Visibility="{Binding ShowFFmpegDownloadButton, Converter={local:BoolToVisibilityConverter}}" />
                                <Button Margin="0,20,0,0" Padding="24,10"
                                        HorizontalAlignment="Center"
                                        Command="{Binding DismissErrorCommand}"
                                        Content="Dismiss"
                                        Style="{StaticResource PlayerButton}"
                                        Visibility="{Binding CanDismissError, Converter={local:BoolToVisibilityConverter}}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--  No Clip Selected  -->
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="24" Foreground="#666"
                               Text="Select a clip to play"
                               Visibility="{Binding HasNoClipSelected, Converter={local:BoolToVisibilityConverter}}" />
                </Grid>

                <!--  Player Controls  -->
                <Border Grid.Row="1"
                        Padding="16"
                        Background="#252525">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Progress Bar  -->
                        <Grid Grid.Row="0"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       MinWidth="50"
                                       VerticalAlignment="Center"
                                       FontSize="13" Foreground="#aaa"
                                       Text="{Binding PositionText}" />

                            <Slider x:Name="SeekSlider"
                                    Grid.Column="1"
                                    IsEnabled="{Binding CanSeek}"
                                    Maximum="1" Minimum="0"
                                    PreviewMouseDown="SeekSlider_PreviewMouseDown"
                                    PreviewMouseUp="SeekSlider_PreviewMouseUp"
                                    Style="{StaticResource SeekSlider}"
                                    ValueChanged="SeekSlider_ValueChanged"
                                    Value="{Binding SeekPosition, Mode=TwoWay}" />

                            <TextBlock Grid.Column="2"
                                       MinWidth="50"
                                       VerticalAlignment="Center"
                                       FontSize="13" Foreground="#aaa"
                                       Text="{Binding DurationText}"
                                       TextAlignment="Right" />
                        </Grid>

                        <!--  Control Buttons  -->
                        <StackPanel Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <Button Command="{Binding PreviousCommand}"
                                    Content="⏮" FontSize="18"
                                    IsEnabled="{Binding CanGoPrevious}"
                                    Style="{StaticResource PlayerButton}"
                                    ToolTip="Previous Clip" />

                            <Button x:Name="PlayPauseButton"
                                    Padding="20,8"
                                    Command="{Binding PlayPauseCommand}"
                                    Content="{Binding PlayPauseIcon}"
                                    FontSize="20"
                                    IsEnabled="{Binding CanPlayPause}"
                                    Style="{StaticResource PlayerButton}"
                                    ToolTip="Play/Pause (Space)" />

                            <Button Command="{Binding NextCommand}"
                                    Content="⏭" FontSize="18"
                                    IsEnabled="{Binding CanGoNext}"
                                    Style="{StaticResource PlayerButton}"
                                    ToolTip="Next Clip" />

                            <Rectangle Width="20" />

                            <Button Command="{Binding StopCommand}"
                                    Content="⏹" FontSize="18"
                                    IsEnabled="{Binding CanStop}"
                                    Style="{StaticResource PlayerButton}"
                                    ToolTip="Stop" />

                            <Rectangle Width="20" />

                            <TextBlock Margin="0,0,8,0" VerticalAlignment="Center"
                                       Foreground="#aaa" Text="Speed" />

                            <ComboBox Width="90" Height="34"
                                      VerticalContentAlignment="Center"
                                      Background="#333" BorderThickness="0"
                                      Foreground="White"
                                      ItemsSource="{Binding PlaybackSpeedOptions}"
                                      SelectedItem="{Binding SelectedPlaybackSpeed, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StringFormat={}{0:0.##}x}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Background="#1a1a1a"
              Visibility="{Binding ShowAboutPage, Converter={local:BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="8">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Padding="10,6"
                            Command="{Binding ToggleAboutCommand}"
                            Content="←"
                            Style="{StaticResource PlayerButton}"
                            ToolTip="Back to Player" />
                    <TextBlock Margin="12,0,0,0"
                               FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Text="About / Help" />
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="20"
                            Background="#252525"
                            CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="26" FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="Sentry Replay" />
                            <TextBlock Margin="0,8,0,16"
                                       FontSize="14"
                                       Foreground="#ddd"
                                       Text="Review TeslaCam footage in a single timeline with easy clip navigation."
                                       TextWrapping="Wrap" />
                            <TextBlock FontSize="16" FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="Quick start" />
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Foreground="#ddd"
                                           Text="• Select Folder to pick your TeslaCam directory."
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="#ddd"
                                           Text="• Choose a clip from the list to start playback."
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="#ddd"
                                           Text="• Use the controls below the video to scrub and change speed."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Margin="0,16,0,0"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="App info" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Foreground="#ccc"
                                           Text="Version:"
                                           TextAlignment="Right" />
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Foreground="#ddd"
                                           Text="{Binding FileVersion}" />
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Foreground="#ccc"
                                           Text="Runtime:"
                                           TextAlignment="Right" />
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Foreground="#ddd"
                                           Text="{Binding RuntimeDescription}" />
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Foreground="#ccc"
                                           Text="OS:"
                                           TextAlignment="Right" />
                                <TextBlock Grid.Row="2" Grid.Column="2"
                                           Foreground="#ddd"
                                           Text="{Binding OsDescription}" />
                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           FontWeight="SemiBold"
                                           Foreground="#ccc"
                                           Text="Exe:"
                                           TextAlignment="Right" />
                                <TextBlock Grid.Row="3" Grid.Column="2"
                                           Foreground="#ddd"
                                           Text="{Binding ExecutablePath}"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0">
                        <Border Padding="20"
                                Background="#252525"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="Shortcuts" />
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Foreground="#ddd"
                                               Text="Space: Play/Pause" />
                                    <TextBlock Foreground="#ddd"
                                               Text="Left/Right: Seek 5 seconds" />
                                    <TextBlock Foreground="#ddd"
                                               Text="Ctrl+Left/Right: Previous/Next clip" />
                                </StackPanel>

                                <TextBlock Margin="0,16,0,0"
                                           FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="Playback notes" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#ddd"
                                           Text="FFmpeg is required for playback. Use the Download FFmpeg button when prompted."
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="#ddd"
                                           Text="If clips do not appear, confirm the folder contains a TeslaCam directory."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="20"
                                Background="#252525"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="Support" />
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Margin="0,0,0,8">
                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            📦 View Sentry Replay on GitHub
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,0,8">
                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay/issues"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            🐛 Report a Bug / Request a Feature
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock>
                                        <Hyperlink NavigateUri="https://github.com/danielchalmers/SentryReplay/releases"
                                                   RequestNavigate="Hyperlink_RequestNavigate">
                                            🚀 Check for Updates
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="20"
                                Background="#252525"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="More from the author" />
                                <UniformGrid Columns="3"
                                             Margin="0,8,0,0">
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/JournalApp"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                Good Diary
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="Track your daily activities and moods on Android." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/DesktopClock"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                DesktopClock
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="A digital clock for your desktop." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/RadialActions"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                Radial Actions
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="Summon a customizable menu at your cursor." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/SteamAccountSwitcher"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                SteamAccountSwitcher
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="Swap Steam accounts from the system tray." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/Network-Monitor"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                Network Monitor
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="Live latency and bandwidth in a desktop widget." />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Style="{StaticResource ProjectTitleTextBlock}">
                                            <Hyperlink NavigateUri="https://github.com/danielchalmers/Teichos"
                                                       RequestNavigate="Hyperlink_RequestNavigate">
                                                Teichos
                                            </Hyperlink>
                                        </TextBlock>
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource ProjectDescriptionTextBlock}"
                                                   Text="Stay focused with URL blocking and schedules." />
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Margin="0,0,0,8">
                                    <Hyperlink NavigateUri="https://github.com/danielchalmers"
                                               RequestNavigate="Hyperlink_RequestNavigate">
                                        View all projects on GitHub
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
