<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        ============================================================
        Motion tokens. The .NET 10 Fluent theme does NOT ship
        Control*AnimationDuration keys, so these are app-local.
        Animate Opacity / RenderTransform only; honor reduced motion.
        ============================================================
    -->
    <Duration x:Key="MotionFaster">
        0:0:0.083
    </Duration>
    <Duration x:Key="MotionFast">
        0:0:0.167
    </Duration>
    <Duration x:Key="MotionNormal">
        0:0:0.25
    </Duration>

    <CubicEase x:Key="AppEaseOut"
               EasingMode="EaseOut" />
    <CubicEase x:Key="AppEaseIn"
               EasingMode="EaseIn" />

    <!--
        ============================================================
        Type ramp (Segoe UI Variable). Set size/weight only; callers
        set Foreground via the semantic TextFillColor* brushes.
        ============================================================
    -->
    <Style x:Key="AppCaption"
           TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="AppBody"
           TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style x:Key="AppBodyStrong"
           TargetType="TextBlock"
           BasedOn="{StaticResource AppBody}">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="AppSubtitle"
           TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="AppTitle"
           TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!--
        ============================================================
        Iconography — Segoe Fluent Icons. Glyphs inherit Foreground
        so they recolor on hover/disabled (the whole reason emoji fail).
        ============================================================
    -->
    <Style x:Key="AppGlyph"
           TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource SymbolThemeFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <!--
        ============================================================
        Buttons. Reuse the Fluent Default/Accent button styles; add
        a subtle icon-button and a press-scale variant WITHOUT
        re-templating, so the Fluent focus visual is preserved.
        ============================================================
    -->

    <!--  Icon-only, flat until hover. 32x32 minimum hit target.  -->
    <Style x:Key="SubtleIconButton"
           TargetType="Button"
           BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource SubtleFillColorTransparentBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!--  Default button + a 0.96 press-scale micro-interaction.  -->
    <Style x:Key="PressScaleButton"
           TargetType="Button"
           BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsPressed" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="0.96"
                                             Duration="{StaticResource MotionFaster}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="0.96"
                                             Duration="{StaticResource MotionFaster}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="{StaticResource MotionFast}" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             To="1"
                                             Duration="{StaticResource MotionFast}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  Icon + label content used inside sidebar buttons.  -->
    <Style x:Key="AppGlyphInButton"
           TargetType="TextBlock"
           BasedOn="{StaticResource AppGlyph}">
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

</ResourceDictionary>
