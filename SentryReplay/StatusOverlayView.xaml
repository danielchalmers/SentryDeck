<UserControl x:Class="SentryReplay.StatusOverlayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SentryReplay"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             d:DesignHeight="700"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Border Background="#80000000"
            Visibility="{Binding State.ShowOverlay, ElementName=Root, Converter={local:BoolToVisibilityConverter}}">
        <StackPanel MaxWidth="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel Visibility="{Binding State.IsLoading, ElementName=Root, Converter={local:BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding State.LoadingStatusText, ElementName=Root}"
                           Margin="0,0,0,16"
                           HorizontalAlignment="Center"
                           FontSize="18"
                           Foreground="{DynamicResource TextControlForeground}" />
                <ProgressBar Width="300"
                             Height="8"
                             IsIndeterminate="{Binding State.IsIndeterminateProgress, ElementName=Root}"
                             Maximum="100"
                             Value="{Binding State.RenderProgressPercent, ElementName=Root, Mode=OneWay}" />
            </StackPanel>

            <StackPanel Visibility="{Binding State.ShowErrorOverlay, ElementName=Root, Converter={local:BoolToVisibilityConverter}}">
                <TextBlock Text="⚠️"
                           Margin="0,0,0,16"
                           HorizontalAlignment="Center"
                           FontSize="48" />
                <TextBlock Text="{Binding State.ErrorTitle, ElementName=Root}"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                <TextBlock Text="{Binding State.ErrorDetails, ElementName=Root}"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource TextControlPlaceholderForeground}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Content="Download FFmpeg"
                        Command="{Binding State.DownloadFFmpegCommand, ElementName=Root}"
                        Margin="0,20,0,0"
                        Padding="24,10"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PlayerButton}"
                        Visibility="{Binding State.ShowFFmpegDownloadButton, ElementName=Root, Converter={local:BoolToVisibilityConverter}}" />
                <Button Content="Dismiss"
                        Command="{Binding State.DismissErrorCommand, ElementName=Root}"
                        Margin="0,20,0,0"
                        Padding="24,10"
                        HorizontalAlignment="Center"
                        Style="{StaticResource PlayerButton}"
                        Visibility="{Binding State.CanDismissError, ElementName=Root, Converter={local:BoolToVisibilityConverter}}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
