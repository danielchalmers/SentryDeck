<UserControl x:Class="SentryReplay.VideoPlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fl="clr-namespace:FlyleafLib.Controls.WPF;assembly=FlyleafLib"
             xmlns:local="clr-namespace:SentryReplay"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=local:VideoPlayerView}"
             mc:Ignorable="d">

    <Grid x:Name="Root"
          Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Video Container  -->
        <Grid Grid.Row="0">
            <!--  Video Player  -->
            <Grid ClipToBounds="True"
                  Background="Black"
                  Visibility="{Binding ShowVideoHosts, Converter={local:BoolToVisibilityConverter}}">
                <fl:FlyleafHost x:Name="FrontFlyleafHost" />

                <Border Width="280"
                        Height="210"
                        Margin="0,15,15,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="Black">
                    <fl:FlyleafHost x:Name="BackFlyleafHost" />
                </Border>

                <Border Width="280"
                        Height="210"
                        Margin="15,0,0,15"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="Black">
                    <fl:FlyleafHost x:Name="LeftFlyleafHost" />
                </Border>

                <Border Width="280"
                        Height="210"
                        Margin="0,0,15,15"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Background="Black">
                    <fl:FlyleafHost x:Name="RightFlyleafHost" />
                </Border>
            </Grid>

            <local:StatusOverlayView CanDismissError="{Binding CanDismissError}"
                                     DismissErrorCommand="{Binding DismissErrorCommand}"
                                     DownloadFFmpegCommand="{Binding DownloadFFmpegCommand}"
                                     ErrorDetails="{Binding ErrorDetails}"
                                     ErrorTitle="{Binding ErrorTitle}"
                                     IsIndeterminateProgress="{Binding IsIndeterminateProgress}"
                                     IsLoading="{Binding IsLoading}"
                                     LoadingStatusText="{Binding LoadingStatusText}"
                                     RenderProgressPercent="{Binding RenderProgressPercent}"
                                     ShowErrorOverlay="{Binding ShowErrorOverlay}"
                                     ShowFFmpegDownloadButton="{Binding ShowFFmpegDownloadButton}"
                                     ShowStatusOverlay="{Binding ShowStatusOverlay}" />

            <!--  No Clip Selected  -->
            <TextBlock Text="Select a clip to play"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="24"
                       Foreground="{DynamicResource TextControlPlaceholderForeground}"
                       Visibility="{Binding HasNoClipSelected, Converter={local:BoolToVisibilityConverter}}" />
        </Grid>

        <!--  Player Controls  -->
        <Border Grid.Row="1"
                Padding="16"
                Background="{DynamicResource ControlAltFillColorSecondaryBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Progress Bar  -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding PositionText}"
                               MinWidth="50"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}" />

                    <Slider x:Name="SeekSlider"
                            Grid.Column="1"
                            IsEnabled="{Binding CanSeek}"
                            Maximum="1"
                            Minimum="0"
                            PreviewMouseDown="SeekSlider_PreviewMouseDown"
                            PreviewMouseUp="SeekSlider_PreviewMouseUp"
                            Style="{StaticResource SeekSlider}"
                            ValueChanged="SeekSlider_ValueChanged"
                            Value="{Binding SeekPosition, Mode=TwoWay}" />

                    <TextBlock Grid.Column="2"
                               Text="{Binding DurationText}"
                               MinWidth="50"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}"
                               TextAlignment="Right" />
                </Grid>

                <!--  Control Buttons  -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Content="⏮"
                            Command="{Binding PreviousCommand}"
                            FontSize="18"
                            IsEnabled="{Binding CanGoPrevious}"
                            Style="{StaticResource PlayerButton}"
                            ToolTip="Previous Clip" />

                    <Button x:Name="PlayPauseButton"
                            Content="{Binding PlayPauseIcon}"
                            Command="{Binding PlayPauseCommand}"
                            Padding="20,8"
                            FontSize="20"
                            IsEnabled="{Binding CanPlayPause}"
                            Style="{StaticResource PlayerButton}"
                            ToolTip="Play/Pause (Space)" />

                    <Button Content="⏭"
                            Command="{Binding NextCommand}"
                            FontSize="18"
                            IsEnabled="{Binding CanGoNext}"
                            Style="{StaticResource PlayerButton}"
                            ToolTip="Next Clip" />

                    <Rectangle Width="20" />

                    <Button Content="⏹"
                            Command="{Binding StopCommand}"
                            FontSize="18"
                            IsEnabled="{Binding CanStop}"
                            Style="{StaticResource PlayerButton}"
                            ToolTip="Stop" />

                    <Rectangle Width="20" />

                    <TextBlock Text="Speed"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}" />

                    <ComboBox Width="90"
                              Height="34"
                              VerticalContentAlignment="Center"
                              Background="{DynamicResource TextControlBackground}"
                              BorderThickness="0"
                              Foreground="{DynamicResource TextControlForeground}"
                              ItemsSource="{Binding PlaybackSpeedOptions}"
                              SelectedItem="{Binding SelectedPlaybackSpeed, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat={}{0:0.##}x}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
