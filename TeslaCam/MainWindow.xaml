<Window x:Class="TeslaCam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TeslaCam"
        xmlns:ffme="clr-namespace:Unosquare.FFME;assembly=ffme.win"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:MainWindow}"
        Title="{x:Static local:App.Title}"
        MinWidth="1200"
        MinHeight="700"
        Background="#1a1a1a"
        ContentRendered="Window_ContentRendered"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Converters -->
        <local:TimeSpanToStringConverter x:Key="TimeSpanConverter" />
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />

        <!-- Button Style -->
        <Style x:Key="PlayerButton" TargetType="Button">
            <Setter Property="Background" Value="#333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#666" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#222" />
                                <Setter Property="Foreground" Value="#666" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider Style for Seek Bar -->
        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="8,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#252525">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Search box -->
            <Border Grid.Row="0" Background="#333" Margin="8,8,8,4">
                <Grid>
                    <TextBox x:Name="SearchBox"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="12,10"
                             FontSize="14"
                             VerticalContentAlignment="Center" />
                    <TextBlock Text="Search clips..."
                               Foreground="#666"
                               FontSize="14"
                               Padding="12,10"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Hidden" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilterText}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Clip list -->
            <ListBox Grid.Row="1"
                     x:Name="ClipListBox"
                     ItemsSource="{Binding FilteredClips}"
                     SelectedItem="{Binding SelectedClip, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="4,0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8" />
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Background" Value="#333" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#444" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1e88e5" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="72">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" CornerRadius="4" Background="#222">
                                <Image Source="{Binding ThumbnailPath}"
                                       Stretch="UniformToFill"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:g}'}"
                                           FontSize="12"
                                           Foreground="#aaa"
                                           Margin="0,4,0,0" />
                                <TextBlock FontSize="11" Foreground="#888" Margin="0,2,0,0">
                                    <Run Text="{Binding Chunks.Count, Mode=OneWay}" />
                                    <Run Text="chunks" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Folder picker -->
            <Button Grid.Row="2"
                    Content="📁 Select Folder"
                    Style="{StaticResource PlayerButton}"
                    Margin="8"
                    Padding="12"
                    Click="OpenFolderButton_Click" />
        </Grid>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Stretch"
                      Background="#333" />

        <!-- Video Player Area -->
        <Grid Grid.Column="2" Background="#1a1a1a">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Video Container -->
            <Grid Grid.Row="0">
                <!-- Video Player -->
                <Viewbox Stretch="Uniform">
                    <!-- HW3 = 1280x960, HW4 = 2896x1876 -->
                    <ffme:MediaElement x:Name="MediaElement"
                                       Height="960"
                                       LoadedBehavior="Manual"
                                       UnloadedBehavior="Manual" />
                </Viewbox>

                <!-- Status Overlay (Loading/Rendering/Error) -->
                <Border Background="#80000000"
                        Visibility="{Binding ShowStatusOverlay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="500">
                        <!-- Loading/Rendering status -->
                        <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding LoadingStatusText}"
                                       Foreground="White"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16" />
                            <ProgressBar Width="300"
                                         Height="8"
                                         IsIndeterminate="{Binding IsIndeterminateProgress}"
                                         Value="{Binding RenderProgressPercent, Mode=OneWay}"
                                         Maximum="100" />
                        </StackPanel>
                        
                        <!-- Error display -->
                        <StackPanel Visibility="{Binding ShowErrorOverlay, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="⚠️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16" />
                            <TextBlock Text="{Binding ErrorTitle}"
                                       Foreground="#ff6b6b"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding ErrorDetails}"
                                       Foreground="#aaa"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       HorizontalAlignment="Center" />
                            <Button Content="Dismiss"
                                    Style="{StaticResource PlayerButton}"
                                    Click="DismissErrorButton_Click"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"
                                    Padding="24,10" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- No Clip Selected -->
                <TextBlock Text="Select a clip to play"
                           Foreground="#666"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasNoClipSelected, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <!-- Player Controls -->
            <Border Grid.Row="1" Background="#252525" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Progress Bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PositionText}"
                                   Foreground="#aaa"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   MinWidth="50" />

                        <Slider Grid.Column="1"
                                x:Name="SeekSlider"
                                Style="{StaticResource SeekSlider}"
                                Value="{Binding SeekPosition, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="1"
                                PreviewMouseDown="SeekSlider_PreviewMouseDown"
                                PreviewMouseUp="SeekSlider_PreviewMouseUp"
                                ValueChanged="SeekSlider_ValueChanged"
                                IsEnabled="{Binding CanSeek}" />

                        <TextBlock Grid.Column="2"
                                   Text="{Binding DurationText}"
                                   Foreground="#aaa"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   MinWidth="50"
                                   TextAlignment="Right" />
                    </Grid>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="⏮"
                                Style="{StaticResource PlayerButton}"
                                Click="PreviousButton_Click"
                                IsEnabled="{Binding CanGoPrevious}"
                                ToolTip="Previous Clip"
                                FontSize="18" />

                        <Button x:Name="PlayPauseButton"
                                Content="{Binding PlayPauseIcon}"
                                Style="{StaticResource PlayerButton}"
                                Click="PlayPauseButton_Click"
                                IsEnabled="{Binding CanPlayPause}"
                                ToolTip="Play/Pause (Space)"
                                FontSize="20"
                                Padding="20,8" />

                        <Button Content="⏭"
                                Style="{StaticResource PlayerButton}"
                                Click="NextButton_Click"
                                IsEnabled="{Binding CanGoNext}"
                                ToolTip="Next Clip"
                                FontSize="18" />

                        <Rectangle Width="20" />

                        <Button Content="⏹"
                                Style="{StaticResource PlayerButton}"
                                Click="StopButton_Click"
                                IsEnabled="{Binding CanStop}"
                                ToolTip="Stop"
                                FontSize="18" />

                        <Rectangle Width="20" />

                        <TextBlock Text="Speed"
                                   Foreground="#aaa"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <ComboBox Width="90"
                                  Height="34"
                                  ItemsSource="{Binding PlaybackSpeedOptions}"
                                  SelectedItem="{Binding SelectedPlaybackSpeed, Mode=TwoWay}"
                                  Background="#333"
                                  Foreground="White"
                                  BorderThickness="0"
                                  VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0:0.##}x}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
